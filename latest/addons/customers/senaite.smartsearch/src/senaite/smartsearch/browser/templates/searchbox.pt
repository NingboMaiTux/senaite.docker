<?xml version="1.0" encoding="utf-8"?>
<div id="ss-box-root"
     xmlns:tal="http://xml.zope.org/namespaces/tal"
     tal:define="here_url context/absolute_url"
     style="position:relative; display:inline-block; margin:8px 12px; max-width:320px; font-family:Inter,-apple-system,sans-serif;">
  <input type="text"
         id="ss-box-input"
         placeholder="🔎 智慧搜索：样品 / 批次 / 客户 / 仪器…"
         style="width:100%; padding:7px 10px; font-size:12.5px; border:1px solid rgba(22,32,46,.15); border-radius:7px;"/>
  <div id="ss-box-dropdown"
       style="display:none; position:absolute; top:36px; left:0; width:360px; max-height:400px; overflow-y:auto;
              background:#fff; border:1px solid rgba(22,32,46,.15); border-radius:9px; box-shadow:0 8px 24px rgba(22,32,46,.15); z-index:900;">
  </div>

  <script tal:content="string:const SS_BOX_BASE = '${here_url}';"></script>
  <script>
  //<![CDATA[
  (function(){
    var input = document.getElementById('ss-box-input');
    var dropdown = document.getElementById('ss-box-dropdown');
    var timer = null;

    var TYPE_COLOR = {
      '样品': '#16356E', '批次': '#0E8A79', '客户': '#B8790C',
      '仪器': '#D3212D', '检测项目': '#2E8B57', '检测结果': '#5B6B82'
    };

    function escapeHtml(s){
      return String(s).replace(/[&<>"']/g, function(c){
        return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
      });
    }

    function render(items, query){
      if(!items.length){
        dropdown.innerHTML = '<div style="padding:14px; font-size:12.5px; color:#5B6B82;">没有找到与「' + escapeHtml(query) + '」相关的记录</div>';
        return;
      }
      dropdown.innerHTML = items.map(function(it){
        var color = TYPE_COLOR[it.type_label] || '#5B6B82';
        return '<a href="' + it.url + '" style="display:block; padding:9px 12px; text-decoration:none; color:#16202E; border-bottom:1px solid rgba(22,32,46,.06);">' +
          '<span style="display:inline-block; font-size:10px; font-weight:700; color:' + color + '; background:' + color + '1A; padding:1px 6px; border-radius:10px; margin-right:6px;">' + escapeHtml(it.type_label) + '</span>' +
          '<span style="font-size:13px; font-weight:500;">' + escapeHtml(it.title) + '</span>' +
          (it.state ? '<span style="float:right; font-size:11px; color:#5B6B82;">' + escapeHtml(it.state) + '</span>' : '') +
          '</a>';
      }).join('') + '<a href="' + SS_BOX_BASE + '/@@smartsearch?q=' + encodeURIComponent(query) + '" style="display:block; padding:9px 12px; text-align:center; font-size:12px; color:#16356E; font-weight:600; text-decoration:none;">查看全部结果 →</a>';
    }

    input.addEventListener('input', function(){
      var q = input.value.trim();
      clearTimeout(timer);
      if(q.length < 2){ dropdown.style.display = 'none'; return; }
      timer = setTimeout(function(){
        fetch(SS_BOX_BASE + '/@@smartsearch-api?q=' + encodeURIComponent(q))
          .then(function(r){ return r.json(); })
          .then(function(data){
            dropdown.style.display = 'block';
            render(data.results || [], q);
          });
      }, 250);
    });

    document.addEventListener('click', function(e){
      if(!document.getElementById('ss-box-root').contains(e.target)){
        dropdown.style.display = 'none';
      }
    });
  })();
  //]]>
  </script>
</div>
