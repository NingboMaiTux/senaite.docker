# ============================================================
#  AiConfigTool .gitignore
# ============================================================

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
build/
dist/
.Python
*.so

# ── 虚拟环境 ──
.venv/
venv/
env/
ENV/

# ── 测试 / 覆盖率 ──
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# ── 前端 / Node ──
node_modules/
frontend/dist/
frontend/.vite/
*.local
.eslintcache

# ── 运行时数据（volume 挂载，不入库；保留目录结构用 .gitkeep）──
data/config.json
data/audit.db
data/audit.db-*
data/logs/*
!data/logs/.gitkeep
data/companies/*
!data/companies/.gitkeep
data/sites/*
!data/sites/.gitkeep

# ── 生成产物（gitignore；保留目录用 .gitkeep）──
output/projects/*
!output/projects/.gitkeep
output/evidence_packs/*
!output/evidence_packs/.gitkeep

# ── IDE / 编辑器 ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── 操作系统 ──
.DS_Store
Thumbs.db
desktop.ini

# ── 日志 ──
*.log
